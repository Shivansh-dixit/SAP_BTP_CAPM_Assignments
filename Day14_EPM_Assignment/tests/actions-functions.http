@base = http://localhost:4004/orders

### Create a customer
POST {{base}}/Customers
Content-Type: application/json

{
  "customerName": "Test Customer",
  "email": "test@example.com",
  "city": "Mumbai",
  "country_code": "IN",
  "creditLimit": 500000
}

### Create an order
POST {{base}}/Orders
Content-Type: application/json

{
  "orderNumber": "SO-TEST-001",
  "customer_ID": "cust1111-1234-4a5e-a1b2-c3d4e5f6g7h8",
  "orderDate": "2026-06-02",
  "grossAmount": 1500.00,
  "netAmount": 1271.19,
  "taxAmount": 228.81,
  "status": "New"
}

### Confirm SO-004 (status: New — will succeed)
POST {{base}}/Orders('so444444-1234-4a5e-a1b2-c3d4e5f6g7h8')/OrderService.confirm
Content-Type: application/json

{}

### Try confirm again (should fail — already Confirmed)
POST {{base}}/Orders('so444444-1234-4a5e-a1b2-c3d4e5f6g7h8')/OrderService.confirm
Content-Type: application/json

{}

### Ship SO-004 (after confirming)
POST {{base}}/Orders('so444444-1234-4a5e-a1b2-c3d4e5f6g7h8')/OrderService.ship
Content-Type: application/json

{
  "trackingNumber": "TRK-2026-001",
  "carrier": "BlueDart"
}

### Deliver SO-004
POST {{base}}/Orders('so444444-1234-4a5e-a1b2-c3d4e5f6g7h8')/OrderService.deliver
Content-Type: application/json

{}

### Try cancel SO-001 (status: Delivered — should fail)
POST {{base}}/Orders('so111111-1234-4a5e-a1b2-c3d4e5f6g7h8')/OrderService.cancel
Content-Type: application/json

{
  "reason": "Changed my mind"
}

### Cancel SO-002 (status: Shipped — will succeed)
POST {{base}}/Orders('so222222-1234-4a5e-a1b2-c3d4e5f6g7h8')/OrderService.cancel
Content-Type: application/json

{
  "reason": "Changed my mind"
}

### Get total for SO-003
GET {{base}}/Orders('so333333-1234-4a5e-a1b2-c3d4e5f6g7h8')/OrderService.getTotal()

### Bulk confirm
POST {{base}}/bulkConfirm
Content-Type: application/json

{
  "orderIds": [
    "so333333-1234-4a5e-a1b2-c3d4e5f6g7h8",
    "so444444-1234-4a5e-a1b2-c3d4e5f6g7h8"
  ]
}

### Get order stats for June 2026
GET {{base}}/getOrderStats(year=2026,month=6)

### Get top 3 customers
GET {{base}}/getTopCustomers(limit=3)