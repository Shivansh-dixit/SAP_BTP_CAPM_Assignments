@base = http://localhost:4004/purchasing

### STEP 1: View Dashboard
GET {{base}}/getPurchasingDashboard()

### STEP 2: Create a Purchase Order
POST {{base}}/PurchaseOrders
Content-Type: application/json

{
  "poNumber": "PO-2026-001",
  "supplier_ID": "s1111111-1234-4a5e-a1b2-c3d4e5f6g7h8",
  "orderDate": "2026-06-02",
  "expectedDate": "2026-06-15",
  "status": "Draft",
  "currency_code": "USD",
  "notes": "Monthly restock order"
}

### STEP 3: Add item to PO (paste PO ID from step 2 response)
POST {{base}}/PurchaseOrderItems
Content-Type: application/json

{
  "purchaseOrder_ID": "7d8c03d3-1639-47b9-ac7a-1323d6bfcc07",
  "product_ID": "p3333333-1234-4a5e-a1b2-c3d4e5f6g7h8",
  "quantity": 100,
  "unitPrice": 25.00,
  "currency_code": "USD"
}

### STEP 4: Get PO Summary
GET {{base}}/PurchaseOrders('7d8c03d3-1639-47b9-ac7a-1323d6bfcc07')/PurchasingService.getSummary()

### STEP 5: Submit PO
POST {{base}}/PurchaseOrders('7d8c03d3-1639-47b9-ac7a-1323d6bfcc07')/PurchasingService.submit
Content-Type: application/json

{}

### STEP 6: Try submit again (should fail — not Draft)
POST {{base}}/PurchaseOrders('7d8c03d3-1639-47b9-ac7a-1323d6bfcc07')/PurchasingService.submit
Content-Type: application/json

{}

### STEP 7: Approve the PO
POST {{base}}/PurchaseOrders('7d8c03d3-1639-47b9-ac7a-1323d6bfcc07')/PurchasingService.approve
Content-Type: application/json

{
  "comment": "Approved. Budget available for Q2 restock."
}

### STEP 8: Receive goods (also updates stock!)
POST {{base}}/PurchaseOrders('7d8c03d3-1639-47b9-ac7a-1323d6bfcc07')/PurchasingService.receive
Content-Type: application/json

{
  "notes": "All items received in good condition"
}

### STEP 9: Verify stock was updated for Wireless Mouse (was 4, should be 104)
GET {{base}}/Products('p3333333-1234-4a5e-a1b2-c3d4e5f6g7h8')?$select=productName,stock

### BONUS: Create second PO for rejection test
POST {{base}}/PurchaseOrders
Content-Type: application/json

{
  "poNumber": "PO-2026-002",
  "supplier_ID": "s2222222-1234-4a5e-a1b2-c3d4e5f6g7h8",
  "orderDate": "2026-06-02",
  "status": "Draft",
  "currency_code": "USD"
}

### BONUS: Add item to PO-2 (paste PO-2 ID)
POST {{base}}/PurchaseOrderItems
Content-Type: application/json

{
  "purchaseOrder_ID": "c2ba9f56-b812-4ab4-9677-e7da8ce9969f",
  "product_ID": "p4444444-1234-4a5e-a1b2-c3d4e5f6g7h8",
  "quantity": 50,
  "unitPrice": 85.50,
  "currency_code": "USD"
}

### BONUS: Submit PO-2
POST {{base}}/PurchaseOrders('c2ba9f56-b812-4ab4-9677-e7da8ce9969f')/PurchasingService.submit
Content-Type: application/json

{}

### BONUS: Reject without reason (should fail)
POST {{base}}/PurchaseOrders('c2ba9f56-b812-4ab4-9677-e7da8ce9969f')/PurchasingService.reject
Content-Type: application/json

{}

### BONUS: Reject with reason
POST {{base}}/PurchaseOrders('c2ba9f56-b812-4ab4-9677-e7da8ce9969f')/PurchasingService.reject
Content-Type: application/json

{
  "reason": "Budget exceeded for this quarter. Please reduce quantities and resubmit."
}

### Final Dashboard check
GET {{base}}/getPurchasingDashboard()