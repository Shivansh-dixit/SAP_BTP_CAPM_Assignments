{
  "authenticationMethod": "route",
  "welcomeFile": "/index.html",
  "routes": [
    {
      "source": "^/purchasing/(.*)$",
      "target": "/purchasing/$1",
      "destination": "srv-api",
      "csrfProtection": false,
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/sap/(.*)$",
      "target": "/sap/$1",
      "destination": "srv-api",
      "csrfProtection": false,
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "localDir": "resources/epm_model_1/webapp",
      "authenticationType": "xsuaa"
    }
  ]
}