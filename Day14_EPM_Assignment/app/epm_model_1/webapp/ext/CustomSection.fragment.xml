<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns:m="sap.m">
  <m:VBox class="sapUiSmallMargin" id="orderValueBox">
    <m:Title text="Order Value Status" level="H3" id="orderValueTitle"/>
    <m:Text text="DEBUG: grossAmount = {grossAmount}, type check = {= typeof ${grossAmount}}" id="debugText"/>
    <m:ProgressIndicator
      id="orderValueProgress"
      percentValue="{= Number(${grossAmount}) > 3000 ? 100 : Number(${grossAmount}) / 3000 * 100}"
      displayValue="{= ${grossAmount} + ' / 3,000 budget threshold'}"
      state="{= Number(${grossAmount}) > 2500 ? 'Error' : Number(${grossAmount}) > 1000 ? 'Warning' : 'Success'}"
    />
    <m:Text text="{= Number(${grossAmount}) > 2500 ? 'Manager approval required: Yes' : 'Manager approval required: No'}" class="sapUiTinyMarginTop" id="orderValueText"/>
  </m:VBox>
</core:FragmentDefinition>